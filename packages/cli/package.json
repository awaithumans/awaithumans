{
  "name": "@awaithumans/cli",
  "version": "0.0.1",
  "description": "CLI for awaithumans — scaffold, run server, manage tasks",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "awaithumans": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "awaithumans": "workspace:*",
    "@awaithumans/server": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awaithumans/awaithumans",
    "directory": "packages/cli"
  }
}
