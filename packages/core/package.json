{
  "name": "awaithumans",
  "version": "0.0.1",
  "description": "The human layer for AI agents. Your agents already await promises. Now they can await humans.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awaithumans/awaithumans",
    "directory": "packages/core"
  },
  "keywords": [
    "human-in-the-loop",
    "hitl",
    "ai-agents",
    "langchain",
    "langgraph",
    "temporal",
    "human-review",
    "agent-workflow"
  ]
}
