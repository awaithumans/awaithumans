{
  "name": "awaithumans",
  "version": "0.1.4",
  "description": "HITL infrastructure for AI agents. Your agent calls awaitHuman(), a human reviews via Slack/email/dashboard, agent resumes with a typed response.",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "bin"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "awaithumans": "bin/awaithumans.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    },
    "./temporal": {
      "import": "./dist/adapters/temporal/index.js",
      "types": "./dist/adapters/temporal/index.d.ts"
    },
    "./langgraph": {
      "import": "./dist/adapters/langgraph/index.js",
      "types": "./dist/adapters/langgraph/index.d.ts"
    }
  },
  "peerDependencies": {
    "@temporalio/client": "^1.0.0",
    "@temporalio/workflow": "^1.0.0",
    "@langchain/langgraph": "^0.2.0 || ^1.0.0"
  },
  "peerDependenciesMeta": {
    "@temporalio/client": { "optional": true },
    "@temporalio/workflow": { "optional": true },
    "@langchain/langgraph": { "optional": true }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "vitest": "^4.1.5",
    "typescript": "^5.7.0",
    "@temporalio/workflow": "^1.0.0",
    "@temporalio/client": "^1.0.0",
    "@langchain/langgraph": "^0.2.0 || ^1.0.0"
  },
  "overrides": {
    "langsmith": ">=0.6.0",
    "protobufjs": "^7.5.8"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/awaithumans/awaithumans",
    "directory": "packages/typescript-sdk"
  },
  "keywords": [
    "human-in-the-loop",
    "hitl",
    "human-review",
    "human-feedback",
    "human-approval",
    "approval-workflow",
    "agent-supervision",
    "agent-handoff",
    "agent-workflow",
    "ai-agents",
    "langchain",
    "langgraph",
    "langchainjs",
    "langgraphjs",
    "temporal",
    "temporalio",
    "mcp",
    "claude",
    "anthropic",
    "openai",
    "gpt",
    "callback",
    "webhook",
    "async",
    "await",
    "typescript",
    "zod",
    "edge-runtime",
    "cloudflare-workers",
    "human-layer",
    "agentops",
    "ai-infrastructure"
  ]
}
